import { useState } from 'react';
import { Text, View, TextInput, TouchableOpacity, StyleSheet } from 'react-native';

export default function Aplicacao() {

  const [modelo, setModelo] = useState('');
  const [valor, setValor] = useState('');
  const [ano, setAno] = useState('');
  

  const [dadosExibidos, setDadosExibidos] = useState('');


  const salvar = () => {
    if(modelo && valor && ano) {
      setDadosExibidos(`Carro: ${modelo} \nValor: R$ ${valor} \nAno: ${ano}`);
    } else {
      setDadosExibidos('Por favor, preencha todos os campos!');
    }
  };

  return (
    <View style={styles.tudo}>
      <View>
        <Text style={styles.titulo}>Cadastro de Veículos</Text>
      </View>

      <View style={styles.containerCampo}>
        <Text style={styles.label}>Modelo do Carro:</Text>
        <TextInput
          style={styles.caixaDeTexto}
          placeholder='Ex: Fiat Uno'
          placeholderTextColor='#6f6f6f'
          onChangeText={setModelo}
          value={modelo}
        />
      </View>

      <View style={styles.containerCampo}>
        <Text style={styles.label}>Valor:</Text>
        <TextInput
          style={styles.caixaDeTexto}
          placeholder='Ex: 15000'
          placeholderTextColor='#6f6f6f'
          keyboardType='numeric'
          onChangeText={setValor}
          value={valor}
        />
      </View>

      <View style={styles.containerCampo}>
        <Text style={styles.label}>Ano de Fabricação:</Text>
        <TextInput
          style={styles.caixaDeTexto}
          placeholder='Ex: 1995'
          placeholderTextColor='#6f6f6f'
          keyboardType='numeric'
          onChangeText={setAno}
          value={ano}
        />
      </View>

      <View style={{ margin: 15 }}>
        <TouchableOpacity 
          style={styles.botao} 
          onPress={salvar}
          activeOpacity={0.7}
        >
          <Text style={styles.textoBotao}>Salvar Dados</Text>
        </TouchableOpacity>
      </View>

      {/* Componente Text que exibe os dados salvos */}
      <View style={styles.containerResultado}>
        <Text style={styles.resposta}>{dadosExibidos}</Text>
      </View>
    </View>
  );
}

const styles = StyleSheet.create({
  tudo: {
    backgroundColor: '#000',
    height: '100%',
    width: '100%',
    paddingTop: 50
  },
  titulo: {
    color: '#0081f1',
    fontSize: 25,
    textAlign: 'center',
    fontWeight: 'bold',
    marginBottom: 20
  },
  containerCampo: {
    marginHorizontal: 15,
    marginVertical: 10
  },
  label: {
    color: '#fff',
    marginBottom: 5,
    fontSize: 16
  },
  caixaDeTexto: {
    borderWidth: 1,
    borderColor: '#0081f1',
    color: '#f2f2f2',
    borderRadius: 10,
    paddingLeft: 15,
    height: 50
  },
  botao: {
    backgroundColor: '#0081f1',
    borderRadius: 10,
    paddingVertical: 15,
    alignItems: 'center',
    marginTop: 10
  },
  textoBotao: {
    color: '#fff',
    fontSize: 18,
    fontWeight: 'bold'
  },
  containerResultado: {
    marginTop: 30,
    padding: 20,
    backgroundColor: '#1a1a1a',
    marginHorizontal: 15,
    borderRadius: 10
  },
  resposta: {
    color: '#0081f1',
    fontSize: 18,
    textAlign: 'center'
  }
});
